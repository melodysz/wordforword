.DS_Store
.playwright-cli/

# Generated by scripts/build_articles.py — the GitHub Actions workflow
# (.github/workflows/deploy.yml) regenerates these on every push from
# content/articles/*.md, so they don't need to live in git history. Run
# `python3 scripts/build_articles.py` locally to regenerate them for
# local preview (python3 -m http.server 5500).
/articles/
/publications.html

# Full-resolution illustration masters (tens of MB each) — the site only
# ever uses the small optimized copies in assets/images/carousel/ and
# assets/images/articles/. Keep the originals as local masters only;
# don't bloat git history with them.
/assets/images/ILLUST *.png

